import mido
import matplotlib.pyplot as plt
import pandas as pd
import numpy as np

# Map MIDI pitch numbers to Note Names
NOTE_LABELS = {}
octave_map = ['C', 'C#', 'D', 'D#', 'E', 'F', 'F#', 'G', 'G#', 'A', 'A#', 'B']
for pitch in range(21, 109): # Full Piano Range
    note_name = octave_map[pitch % 12]
    octave = (pitch // 12) - 1
    NOTE_LABELS[pitch] = f"{note_name}{octave}"

def create_piano_roll(midi_file, image_file):
    try:
        mid = mido.MidiFile(midi_file)
        notes = []
        current_time = 0
        
        # 1. Parse MIDI Data
        for msg in mid.tracks[0]:
            current_time += msg.time
            if msg.type == 'note_on' and msg.velocity > 0:
                notes.append({
                    "time": current_time, 
                    "pitch": msg.note,
                    "intensity": 0.3 + (msg.velocity / 127 * 0.7)
                })
                
        if not notes: return False
        df = pd.DataFrame(notes)
        
        # 2. Setup Plot
        fig, ax = plt.subplots(figsize=(10, 5)) # Slightly taller for labels
        fig.patch.set_facecolor('white')
        ax.set_facecolor('white')
        
        # 3. Determine Pitch Range
        min_pitch = df['pitch'].min() - 2
        max_pitch = df['pitch'].max() + 3 # Extra space at top for labels
        pitches_to_show = list(range(min_pitch, max_pitch + 1))
        
        # 4. Draw Staff Lines
        for p in pitches_to_show:
            color = '#e0e0e0'
            linewidth = 0.8
            if '#' not in NOTE_LABELS.get(p, ''):
                color = '#b0b0b0' 
                linewidth = 1.2
            ax.axhline(y=p, color=color, linestyle='-', linewidth=linewidth, zorder=1)

        # 5. Plot the Notes (Dots)
        colors = plt.cm.winter(df['intensity'])
        ax.scatter(df['time'], df['pitch'], c=colors, s=150, edgecolor='black', linewidth=0.5, zorder=2)
        
        # --- NEW: LABEL THE DOTS ---
        for index, row in df.iterrows():
            pitch_val = int(row['pitch'])
            note_name = NOTE_LABELS.get(pitch_val, '?')
            label_text = f"{note_name}\n({pitch_val})"
            
            # Place text slightly above the dot (+0.6 on Y axis)
            ax.text(row['time'], row['pitch'] + 0.6, label_text, 
                    fontsize=7, ha='center', va='bottom', color='#333333', fontweight='bold')

        # 6. Configure Axes
        ax.set_yticks(pitches_to_show)
        ax.set_yticklabels([NOTE_LABELS.get(p, '') for p in pitches_to_show], fontsize=8)
        
        ax.set_xlabel("Time (Ticks)", fontsize=9)
        ax.set_xticks([]) 

        plt.tight_layout()
        plt.savefig(image_file, dpi=100, bbox_inches='tight')
        plt.close(fig)
        return True
        
    except Exception as e:
        print(f"Viz Error: {e}")
        return False